{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "paths": {
      "#/*": [
        "./spore_packages/*"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true
  },
  "extends": "./.svelte-kit/tsconfig.json",
  "include": [
    "src/**/*",
    "spore_packages/**/*"
  ]
}