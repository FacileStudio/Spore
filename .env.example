# Database
POSTGRES_PASSWORD=your_secure_database_password_here

# Auth (CRITICAL: use a long random value in production, min 32 chars)
AUTH_SECRET=your-super-secure-auth-secret-minimum-32-characters-long

# Public URL the frontend uses to reach the API (same origin via nginx).
# Baked into the web build at build time, so set it to the final public domain.
PUBLIC_BACKEND_URL=https://spore.facile.studio

# Optional: Spore Space API URL for the CLI
# SPORE_SPACE_URL=https://spore.facile.studio
